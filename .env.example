# API Keys
GEMINI_API_KEY=

# TTS Configuration
# Para desarrollo en AI Studio (remoto):
VITE_TTS_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/es/es_MX/claude/high/es_MX-claude-high.onnx
VITE_TTS_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/es/es_MX/claude/high/es_MX-claude-high.onnx.json

# Para producción/offline (bundling local):
# 1. Descarga los archivos a /public/models/tts/
# 2. Usa estas rutas:
# VITE_TTS_MODEL_URL=/models/tts/es_MX-claude-high.onnx
# VITE_TTS_CONFIG_URL=/models/tts/es_MX-claude-high.onnx.json

# Local Voice Settings
VITE_DEFAULT_VOICE_MODE=auto

# Piper TTS Parameters (Opcional)
# noiseScale: varianza del sonido (defecto 0.667)
# lengthScale: velocidad, menor es más rápido (defecto 1.0)
# noiseW: varianza fonética (defecto 0.8)
# VITE_TTS_NOISE_SCALE=0.667
# VITE_TTS_LENGTH_SCALE=1.0
# VITE_TTS_NOISE_W=0.8
